{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (Debug)",
            "type": "process",
            "command": "dotnet",
            "args": ["build", "${workspaceFolder}/src/VerBump.csproj"],
            "group": "build",
            "presentation": { "reveal": "silent", "panel": "shared" },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Publish (Release · single exe)",
            "type": "process",
            "command": "dotnet",
            "args": [
                "publish",
                "${workspaceFolder}/src/VerBump.csproj",
                "-c", "Release",
                "-r", "win-x64",
                "--self-contained", "true",
                "-p:PublishSingleFile=true"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$msCompile"
        }
    ]
}
